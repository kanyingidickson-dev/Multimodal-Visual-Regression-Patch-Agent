# Gemma 4 API Configuration

# Option 1: OpenRouter (recommended, free tier available)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Option 2: Hugging Face Inference API
# Get your token at https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# HUGGINGFACE_MODEL=google/gemma-4-31b-it

# Model Selection
# Options: gemma-4-31b (dense), gemma-4-26b-moe (mixture-of-experts), gemma-4-4b (edge)
MODEL_CHOICE=gemma-4-31b

# Mock Mode (for testing/demo without API key)
# Set to true to use realistic mock responses instead of real API calls
MOCK_MODE=true

# Server Configuration
PORT=5000
HOST=127.0.0.1

# Environment (development or production)
ENVIRONMENT=development

# Optional: API key to protect your /api/review endpoint
# Leave empty to disable authentication
# API_KEY=your_secret_api_key_here

# Frontend Configuration
# Backend API URL (for production deployment on Vercel)
# In development, this defaults to /api (proxied by Vite)
# In production, set this to your deployed backend URL
VITE_API_URL=https://your-backend-url.com
